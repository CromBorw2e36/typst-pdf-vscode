{
  "name": "typst-pdf-vscode",
  "displayName": "Masax Typst PDF Editor",
  "description": "Live PDF preview for .typ files with JSON data injection and Typst-native scripting",
  "version": "0.0.4",
  "engines": {
    "vscode": "^1.85.0"
  },
  "publisher": "banhkheokhongbeo",
  "license": "MIT",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/CromBorw2e36/typst-pdf-vscode"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "activationEvents": [
    "onLanguage:typst"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "masax.openPreview",
        "title": "Open Live Preview",
        "icon": "$(open-preview)",
        "category": "Masax Typst"
      },
      {
        "command": "masax.exportPDF",
        "title": "Export to PDF",
        "icon": "$(file-pdf)",
        "category": "Masax Typst"
      },
      {
        "command": "masax.openDataEditor",
        "title": "Open JSON Data Panel",
        "icon": "$(json)",
        "category": "Masax Typst"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "when": "resourceExtname == .typ",
          "command": "masax.openPreview",
          "group": "navigation@1"
        },
        {
          "when": "resourceExtname == .typ",
          "command": "masax.openDataEditor",
          "group": "navigation@2"
        },
        {
          "when": "resourceExtname == .typ",
          "command": "masax.exportPDF",
          "group": "navigation@3"
        }
      ],
      "editor/context": [
        {
          "when": "resourceExtname == .typ",
          "command": "masax.openPreview",
          "group": "masax@1"
        },
        {
          "when": "resourceExtname == .typ",
          "command": "masax.openDataEditor",
          "group": "masax@2"
        },
        {
          "when": "resourceExtname == .typ",
          "command": "masax.exportPDF",
          "group": "masax@3"
        }
      ],
      "explorer/context": [
        {
          "when": "resourceExtname == .typ",
          "command": "masax.openPreview",
          "group": "masax"
        }
      ]
    },
    "keybindings": [
      {
        "command": "masax.openPreview",
        "key": "ctrl+shift+v",
        "mac": "cmd+shift+v",
        "when": "resourceExtname == .typ"
      },
      {
        "command": "masax.exportPDF",
        "key": "ctrl+shift+e",
        "mac": "cmd+shift+e",
        "when": "resourceExtname == .typ"
      }
    ],
    "languages": [
      {
        "id": "typst",
        "extensions": [
          ".typ"
        ],
        "aliases": [
          "Typst"
        ]
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile && npm run copy-lib",
    "compile": "tsc -p ./",
    "copy-lib": "node -e \"require('fs').cpSync('../dist/masax-typst-pdf.full.js', 'media/masax-typst-pdf.full.js', {force:true})\"",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test",
    "package": "npm run copy-lib && vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.85.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.7.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
