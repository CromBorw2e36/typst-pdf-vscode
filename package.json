{
  "name": "typst-pdf-vscode",
  "displayName": "Masax Typst PDF Editor",
  "description": "Live PDF preview for .typ files with JSON data binding and console output",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "activationEvents": [
    "onLanguage:typst"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "masax.openPreview",
        "title": "Masax: Open Live PDF Preview",
        "icon": "$(open-preview)"
      },
      {
        "command": "masax.exportPDF",
        "title": "Masax: Export to PDF"
      },
      {
        "command": "masax.openDataEditor",
        "title": "Masax: Open JSON Data Panel"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "when": "resourceExtname == .typ",
          "command": "masax.openPreview",
          "group": "navigation"
        }
      ]
    },
    "languages": [
      {
        "id": "typst",
        "extensions": [".typ"],
        "aliases": ["Typst"]
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.110.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
